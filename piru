    chakraFill.BorderSizePixel = 0
    chakraFill.Parent = chakraBg
    
    local chakraText = Instance.new("TextLabel")
    chakraText.Size = UDim2.new(0, 40, 0, 15)
    chakraText.Position = UDim2.new(0, 265, 0, 45)
    chakraText.BackgroundTransparency = 1
    chakraText.Text = math.floor(playerData.Chakra) .. "%"
    chakraText.TextColor3 = Color3.fromRGB(255, 255, 255)
    chakraText.TextScaled = true
    chakraText.Font = Enum.Font.Gotham
    chakraText.Parent = frame
    
    -- Salvar referências para atualização
    playerButtons[playerData.UserId] = {
        Frame = frame,
        ChakraFill = chakraFill,
        ChakraText = chakraText
    }
    
    return frame
end

-- Função para atualizar a lista de jogadores
local function updatePlayerList(playersData)
    -- Verificar se a UI existe
    if not screenGui or not screenGui.Parent then
        createMainUI()
    end
    
    local scrollingFrame = playerListFrame:FindFirstChild("ScrollingFrame")
    if not scrollingFrame then return end
    
    -- Limpar lista atual (manter apenas o layout)
    for _, child in pairs(scrollingFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name ~= "UIListLayout" then
            child:Destroy()
        end
    end
    
    -- Limpar referências
    playerButtons = {}
    
    -- Adicionar todos os jogadores
    for _, data in ipairs(playersData) do
        createPlayerItem(data, scrollingFrame)
    end
end

-- Função para atualizar chakra de um jogador
local function updatePlayerChakra(updatedPlayer, chakraValue)
    local userId = updatedPlayer.UserId
    
    if playerButtons[userId] then
        local chakraFill = playerButtons[userId].ChakraFill
        local chakraText = playerButtons[userId].ChakraText
        
        if chakraFill then
            chakraFill.Size = UDim2.new(chakraValue/100, 0, 1, 0)
        end
        
        if chakraText then
            chakraText.Text = math.floor(chakraValue) .. "%"
        end
    end
end

-- Conectar eventos
updatePlayerListEvent.OnClientEvent:Connect(updatePlayerList)
updateChakraEvent.OnClientEvent:Connect(updatePlayerChakra)

